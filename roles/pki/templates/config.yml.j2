---
# The version of the configuration file format.
version: "{{ config_overrides.version }}"
{% if 'certificate_signing_provider' in config_overrides %}

# Specifies the provider that will be used to sign the certificates.
# Options:
#   "vault": HashiCorp Vault PKI Engine (default).
#   "openssl": The local OpenSSL tool.
certificate_signing_provider: "{{ config_overrides.certificate_signing_provider }}"
{% endif %}
{% if 'secret_provider' in config_overrides %}

# Secret storage provider for passwords and sensitive data.
# Options:
#   "vault": HashiCorp Vault Secret Engine (default).
#   "keyring" (Ubuntu).
#   "keychain" (MacOS).
secret_provider: "{{ config_overrides.secret_provider }}"
{% endif %}
{% if 'private_key' in config_overrides %}

# Variables that will be used for creating a private key.
# https://docs.ansible.com/ansible/latest/collections/community/crypto/openssl_privatekey_module.html
private_key:
{% if 'extension' in config_overrides.private_key %}
  # Extension for the private key file.
  # Common extensions include 'key' or 'pem'.
  extension: "{{ config_overrides.private_key.extension }}"
{% endif %}
{% if 'format' in config_overrides.private_key %}
  # Determines which format the private key is written in.
  # By default, PKCS1 (traditional OpenSSL format) is used for all keys which support it.
  # Please note that not every key can be exported in any format.
  # The value "auto" selects a format based on the key format.
  # The value "auto_ignore" does the same, but for existing private key files,
  # it will not force a regenerate when its format is not the automatically selected one for generation.
  # Note that if the format for an existing private key mismatches, the key is regenerated by default.
  # To change this behavior, use the format_mismatch option.
  # Choices: [pkcs1, pkcs8, raw, auto, auto_ignore]
  format: "{{ config_overrides.private_key.format }}"
{% endif %}
{% if 'type' in config_overrides.private_key %}
  # Type of the private key to be generated.
  # Determines the algorithm used for generating the private key.
  # Common options include:
  # - 'DSA': Less commonly used, mainly for compatibility with older systems.
  # - 'ECC': Uses elliptic curve cryptography for smaller key sizes and faster performance.
  # - 'Ed25519': A modern elliptic curve algorithm known for its speed and security.
  # - 'Ed448': A variant of Ed25519 with a larger key size for enhanced security.
  # - 'RSA': Widely used and supports various key lengths (e.g., 2048, 4096 bits).
  # - 'X25519': Primarily used for key exchange in secure communications.
  # - 'X448': A variant of X25519 with a larger key size for enhanced security.
  type: "{{ config_overrides.private_key.type }}"
{% endif %}
{% if 'size' in config_overrides.private_key %}
  # The size of the private key in bits.
  # Common sizes for RSA keys are 2048, 3072, or 4096 bits.
  # Size of the private key in bits.
  # For RSA, 2048 was a standard size, balancing security and performance.
  # To improved security, 3072 is default for RSA type.
  size: {{ config_overrides.private_key.size }}
{% endif %}
{% if 'curve' in config_overrides.private_key %}
  # For ECC, 256 is a standard size, balancing security and performance.
  # ECC 256 equivalent to 3072 RSA key, use: secp256r1 (default).
  # ECC 384 equivalent to 7680 RSA key, use: secp384r1.
  # ECC 512 equivalent to 10752 RSA key, use: secp512r1.
  curve: "{{ config_overrides.private_key.curve }}"
{% endif %}
{% if 'cipher' in config_overrides.private_key %}
  # Cipher to be used for encrypting the private key.
  # This defines how the private key will be secured when stored.
  # Common options include:
  # - 'auto': Automatically selects the best available cipher based on OpenSSL defaults.
  # - 'aes256': Uses AES with a 256-bit key for strong encryption.
  # - 'des3': Uses Triple DES for encryption, though it's considered less secure than AES.
  cipher: "{{ config_overrides.private_key.cipher }}"
{% endif %}
{% if 'passphrase' in config_overrides.private_key %}
  # Passphrase for the private key file.
  # - An empty string ("") means no passphrase will be used for the private key (default).
  # - A question mark ("?") triggers the automatic generation of a random passphrase.
  # - Any other string (e.g., "SuperSecretPassword") will be used as the explicit passphrase.
  passphrase: "{{ config_overrides.private_key.passphrase }}"
{% endif %}
{% if 'passphrase_size' in config_overrides.private_key %}
  # Length of the random passphrase if 'passphrase' is set to "?".
  # A size of 30 characters provides strong security for the passphrase.
  passphrase_size: {{ config_overrides.private_key.passphrase_size }}
{% endif %}
{% endif %}
{% if 'csr' in config_overrides %}

# Variables that will be used for creating a certificate signing request.
# https://docs.ansible.com/ansible/latest/collections/community/crypto/openssl_csr_module.html
csr:
{% if 'extension' in config_overrides.csr %}
  # Extension for the CSR file.
  # Common extensions include 'csr' or 'pem'.
  extension: "{{ config_overrides.csr.extension }}"
{% endif %}
{% if 'digest' in config_overrides.csr %}
  # Digest algorithm to be used for signing the CSR (Certificate Signing Request).
  # Determines the hashing algorithm used when creating the CSR.
  # Common options include:
  # - 'sha1': Older and less secure, but still supported for legacy systems.
  # - 'sha256': A strong and widely used digest, considered a secure default.
  # - 'sha512': A stronger alternative to 'sha256', providing even more security.
  digest: "{{ config_overrides.csr.digest }}"
{% endif %}
{% if 'country_name' in config_overrides.csr %}
  # Country name to be included in the CSR.
  # Use the two-letter ISO 3166-1 country code.
  country_name: "{{ config_overrides.csr.country_name }}"
{% endif %}
{% if 'state_or_province_name' in config_overrides.csr %}
  # State or province name to be included in the CSR.
  state_or_province_name: "{{ config_overrides.csr.state_or_province_name }}"
{% endif %}
{% if 'locality_name' in config_overrides.csr %}
  # Locality or city name to be included in the CSR.
  locality_name: "{{ config_overrides.csr.locality_name }}"
{% endif %}
{% if 'organization_name' in config_overrides.csr %}
  # Organization name to be included in the CSR.
  organization_name: "{{ config_overrides.csr.organization_name }}"
{% endif %}
{% if 'organizational_unit_name' in config_overrides.csr %}
  # Organizational unit name to be included in the CSR.
  organizational_unit_name: "{{ config_overrides.csr.organizational_unit_name }}"
{% endif %}
{% if 'email_address' in config_overrides.csr %}
  # Email address to be included in the CSR.
  email_address: "{{ config_overrides.csr.email_address }}"
{% endif %}
{% if 'common_name' in config_overrides.csr %}
  # Common name (usually the domain name) to be included in the CSR.
  # This field is often required for SSL/TLS certificates.
  common_name: "{{ config_overrides.csr.common_name }}"
{% endif %}
{% if 'subject_alt_name' in config_overrides.csr %}
  # Subject Alternative Names (SANs) to be included in the CSR.
  # This is a list of additional names (e.g., domain names) the certificate should cover.
  # Example:
  # subject_alt_name:
    # - "DNS:site.{{ context_vars.certificate_domain }}"
    # - "DNS:othersan.{{ context_vars.certificate_domain }}"
  subject_alt_name:{{ ('') if (config_overrides.csr.subject_alt_name | default([]) | length > 0) else " []" }}
{% for element in config_overrides.csr.subject_alt_name | default([]) %}
    - "{{ element }}"
{% endfor %}
{% endif %}
{% if 'basic_constraints' in config_overrides.csr %}
  # Basic constraints to be included in the CSR.
  # 'CA:TRUE' indicates that this certificate can be used to sign other certificates.
  #  ,pathlen:1 means this Root CA can sign intermediate CAs (1 level down), but not end-entity certificates.
  #  ,pathlen:0 means this Sub CA can sign end-entity certificates, but cannot sign other CAs.
  # 'CA:FALSE' indicates that this certificate cannot be used to sign other certificates.
  basic_constraints: "{{ config_overrides.csr.basic_constraints }}"
{% endif %}
{% if 'basic_constraints_critical' in config_overrides.csr %}
  # Indicates whether the basic constraints extension is critical.
  # If true, the extension must be understood and processed by the receiving party.
  basic_constraints_critical: {{ config_overrides.csr.basic_constraints_critical | lower }}
{% endif %}
{% if 'key_usage' in config_overrides.csr %}
  # Key usage extensions to be included in the CSR (Certificate Signing Request).
  # This defines the allowed cryptographic operations for the key.
  # key_usage:
    # - "digitalSignature" # Sign data for authentication, integrity, TLS handshakes, CRLs, OCSP responses.
    # - "keyEncipherment"  # Encrypt symmetric keys for transfer (RSA key exchange).
    # - "keyAgreement"     # Establish symmetric keys via key agreement (ECDHE/DHE) - recommended for modern TLS.
    # - "nonRepudiation"   # Prevents signing entity from denying an action (legal/audit contexts).
    # - "dataEncipherment" # Encrypt/decrypt actual application data (rarely used).
    # - "keyCertSign"      # Sign certificates - CA certificates ONLY (Root CA signs Sub CAs, Sub CA signs end-entity certs).
    # - "cRLSign"          # Sign certificate revocation lists (CRLs) - CA certificates ONLY.
  key_usage:{{ ('') if (config_overrides.csr.key_usage | default([]) | length > 0) else " []" }}
{% for element in config_overrides.csr.key_usage | default([]) %}
    - "{{ element }}"
{% endfor %}
{% endif %}
{% if 'key_usage_critical' in config_overrides.csr %}
  # Indicates whether the key usage extension is critical.
  key_usage_critical: {{ config_overrides.csr.key_usage_critical | lower }}
{% endif %}
{% if 'extended_key_usage' in config_overrides.csr %}
  # Extended key usage extensions to be included in the CSR.
  # This further refines the specific purposes of the key in different contexts.
  # extended_key_usage:
    # - "serverAuth"      # For SSL/TLS server authentication.
    # - "clientAuth"      # For SSL/TLS client authentication.
    # - "emailProtection" # For securing email communications.
    # - "codeSigning"     # For signing executable code to ensure authenticity.
    # - "timeStamping"    # For creating secure timestamps.
  extended_key_usage:{{ ('') if (config_overrides.csr.extended_key_usage | default([]) | length > 0) else " []" }}
{% for element in config_overrides.csr.extended_key_usage | default([]) %}
    - "{{ element }}"
{% endfor %}
{% endif %}
{% if 'extended_key_usage_critical' in config_overrides.csr %}
  # Indicates whether the extended key usage extension is critical.
  extended_key_usage_critical: {{ config_overrides.csr.extended_key_usage_critical | lower }}
{% endif %}
{% endif %}
{% if 'certificate' in config_overrides %}

# Variables that will be used for creating a certificate.
# https://docs.ansible.com/ansible/latest/collections/community/crypto/x509_certificate_module.html
certificate:
{% if 'extension' in config_overrides.certificate %}
  # Extension for the certificate file.
  # Common extensions include 'cer', 'crt', or 'pem'.
  extension: "{{ config_overrides.certificate.extension }}"
{% endif %}
{% if 'digest' in config_overrides.certificate %}
  # Digest algorithm to be used for signing certificates.
  # Determines the hashing algorithm used for certificate signing.
  # Common options include:
  # - 'sha256': A secure and standard choice for most modern systems.
  # - 'sha512': A stronger alternative for higher security requirements.
  digest: "{{ config_overrides.certificate.digest }}"
{% endif %}
{% if 'not_after' in config_overrides.certificate %}
  # Sets the expiration date of the certificate.
  # Can be set using relative times (e.g., "+365d") or a specific date (e.g., "2024-12-31").
  not_after: "{{ config_overrides.certificate.not_after }}"
{% endif %}
{% if 'provider' in config_overrides.certificate %}
  # Specifies the provider for OpenSSL certificate creation.
  # This is only used when certificate_signing_provider is set to "openssl".
  # Options:
  #   "selfsigned": Creates a self-signed certificate (typically for root CAs).
  #   "ownca": Signs certificate using a custom local OpenSSL Certificate Authority.
  provider: "{{ config_overrides.certificate.provider }}"
{% endif %}
{% if 'ownca' in config_overrides.certificate %}
  # OwnCA configuration (only used when certificate_signing_provider is set to "openssl" and provider is set to "ownca").
  # These settings define the Certificate Authority that will sign the certificate.
  ownca:
{% if 'name' in config_overrides.certificate.ownca %}
    # The name of the Certificate Authority certificate (without extension).
    # This typically corresponds to the common name of the CA.
    # Example: "sub-ca.lan.home"
    name: "{{ config_overrides.certificate.ownca.name }}"
{% endif %}
{% if 'path' in config_overrides.certificate.ownca %}
    # The directory path where the CA certificate and private key are stored.
    # Example: "{{ context_vars.certificates_base_path }}/2026/lan.home/prd/sub-ca"
    path: "{{ config_overrides.certificate.ownca.path }}"
{% endif %}
{% endif %}
{% endif %}
{% if 'pkcs12' in config_overrides %}

# Variables that will be used for creating a PKCS12 file.
# https://docs.ansible.com/ansible/latest/collections/community/crypto/openssl_pkcs12_module.html
pkcs12:
{% if 'extension' in config_overrides.pkcs12 %}
  # Extension for the PKCS12 file, which stores both the certificate and its private key.
  # Common extensions include 'p12' or 'pfx'.
  extension: "{{ config_overrides.pkcs12.extension }}"
{% endif %}
{% if 'encryption' in config_overrides.pkcs12 %}
  # Determines the encryption level used.
  # - 'auto' uses the default of the selected backend.
  #   For cryptography, this is what the cryptography library's specific version considers the best available encryption.
  # - 'compatibility2022' uses compatibility settings for older software in 2022.
  #   This is only supported by the cryptography backend if cryptography >= 38.0.0 is available.
  # Choices: [auto,compatibility2022] Default: auto
  encryption: "{{ config_overrides.pkcs12.encryption }}"
{% endif %}
{% if 'action' in config_overrides.pkcs12 %}
  # Action related to the PKCS12 file.
  # 'export' means the certificate and its private key will be exported to a file.
  action: "{{ config_overrides.pkcs12.action }}"
{% endif %}
{% if 'friendly_name' in config_overrides.pkcs12 %}
  # A friendly name for the PKCS12 file, used when importing it into a keystore.
  friendly_name: "{{ config_overrides.pkcs12.friendly_name }}"
{% endif %}
{% endif %}
{% if 'auto_renewal' in config_overrides %}

auto_renewal:
{% if 'enabled' in config_overrides.auto_renewal %}
  # Enables or disables the auto-renewal feature.
  # When enabled, certificates nearing expiration will be automatically renewed based on the defined criteria.
  enabled: {{ config_overrides.auto_renewal.enabled | lower }}
{% endif %}
{% if 'days_for_yellow_alert' in config_overrides.auto_renewal %}
  # Number of days before expiration to trigger yellow/warning status.
  days_for_yellow_alert: {{ config_overrides.auto_renewal.days_for_yellow_alert }}
{% endif %}
{% if 'days_for_red_alert' in config_overrides.auto_renewal %}
  # Number of days before expiration to trigger red/critical status.
  days_for_red_alert: {{ config_overrides.auto_renewal.days_for_red_alert }}
{% endif %}
{% if 'days_before_expiration' in config_overrides.auto_renewal %}
  # Number of days before expiration to trigger auto-renewal.
  # If the certificate is set to expire within this number of days, it will be automatically renewed.
  days_before_expiration: {{ config_overrides.auto_renewal.days_before_expiration }}
{% endif %}
{% if 'certificate_pki_pipeline_window' in config_overrides.auto_renewal %}
  # Maintenance windows for certificate import operations.
  # Each window defines when certificate imports are allowed.
  # Empty list [] means imports allowed at any time.
  certificate_pki_pipeline_window:{{ ('') if (config_overrides.auto_renewal.certificate_pki_pipeline_window | default([]) | length > 0) else " []" }}
{% for element in config_overrides.auto_renewal.certificate_pki_pipeline_window | default([]) %}
    - "{{ element }}"
{% endfor %}
  # Valid day names: monday, tuesday, wednesday, thursday, friday, saturday, sunday.
  # Time format: 'HH:MM' in 24-hour format.
  # Day names are case insensitive (MONDAY, monday, MonDAY all accepted).
  # certificate_pki_pipeline_window:
  #   # Example 1: Weekday evening window.
  #   - days: ["monday", "tuesday", "wednesday", "thursday", "friday"]
  #     start_time: '18:00'  # 6:00 PM time.
  #     end_time: '23:59'    # 11:59 PM time.
  #   # Example 2: Weekend all-day window.
  #   - days: ["saturday", "sunday"]
  #     start_time: '00:00'  # Midnight.
  #     end_time: '23:59'    # 11:59 PM.
  #   # Example 3: Overnight window (crosses midnight).
  #   - days: ["sunday"]     # Sunday night into Monday.
  #     start_time: '23:00'  # 11:00 PM Sunday.
  #     end_time: '06:00'    # 6:00 AM Monday (next day).
{% endif %}
{% endif %}
{% if 'notification_mail' in config_overrides %}

# Variables that will be used for sending email notifications about the certificates.
# https://docs.ansible.com/ansible/latest/collections/community/general/mail_module.html
notification_mail:
{% if 'host' in config_overrides.notification_mail %}
  # SMTP server settings for sending email notifications.
  host: "{{ config_overrides.notification_mail.host }}"
{% endif %}
{% if 'port' in config_overrides.notification_mail %}
  # SMTP server port.
  port: {{ config_overrides.notification_mail.port }}
{% endif %}
{% if 'secure' in config_overrides.notification_mail %}
  # Type of security to use for the SMTP connection.
  # Options:
  # - "none": No security (not recommended).
  # - "ssl": Use SSL/TLS for the connection.
  # - "starttls": Use STARTTLS to upgrade the connection to a secure one (recommended).
  secure: "{{ config_overrides.notification_mail.secure }}"
{% endif %}
{% if 'smtp_username' in config_overrides.notification_mail %}
  # The username for the SMTP server.
  smtp_username: "{{ config_overrides.notification_mail.smtp_username }}"
{% endif %}
{% if 'smtp_password_id' in config_overrides.notification_mail %}
  # The ID of the SMTP password stored in the Secret Management system.
  smtp_password_id: "{{ config_overrides.notification_mail.smtp_password_id }}"
{% endif %}
{% if 'from' in config_overrides.notification_mail %}
  # Email details for sending notifications.
  from: "{{ config_overrides.notification_mail.from }}"
{% endif %}
{% if 'to' in config_overrides.notification_mail %}
  # Recipients of the notification emails.
  to:{{ ('') if (config_overrides.notification_mail.to | default([]) | length > 0) else " []" }}
{% for element in config_overrides.notification_mail.to | default([]) %}
    - "{{ element }}"
{% endfor %}
{% endif %}
{% if 'cc' in config_overrides.notification_mail %}
  # Carbon copy recipients of the notification emails.
  cc:{{ ('') if (config_overrides.notification_mail.cc | default([]) | length > 0) else " []" }}
{% for element in config_overrides.notification_mail.cc | default([]) %}
    - "{{ element }}"
{% endfor %}
{% endif %}
{% if 'subtype' in config_overrides.notification_mail %}
  # Format of the email body.
  subtype: "{{ config_overrides.notification_mail.subtype }}"
{% endif %}
{% endif %}